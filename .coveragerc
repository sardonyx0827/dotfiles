# Coverage configuration for the Python hook / MCP test suite.
# Measured by pytest-cov in CI (see .github/workflows/ci.yml).
[run]
branch = true
# .codex/hooks/_bash_review_common.py used to be omitted here: it was a
# byte-identical twin that always reported 0% because Python's module cache
# exec'd only the .claude copy. It is now a symlink to that copy, so there is
# a single measured file and nothing left to exclude.

[report]
show_missing = true
skip_covered = false
exclude_also =
    if __name__ == .__main__.:
    raise NotImplementedError
