[alias]
  ls = log --graph --date-order -C -M --pretty=format:\"<%h> %ad [%an] %Cgreen%d%Creset %s\" --all --date=short
  ll = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
  la = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
[credential "https://github.com"]
  helper =
  helper = !gh auth git-credential
[credential "https://gist.github.com"]
  helper =
  helper = !gh auth git-credential
[core]
  editor = nvim
  excludesfile = ~/.gitignore_global
[http]
  sslVerify = true
# 汎用の資格情報ヘルパーは OS 依存 (macOS: osxkeychain / Linux: cache) のため、
# tracked な .gitconfig には直書きせず install.sh が生成する
# ~/.config/git/os.gitconfig に切り出す。osxkeychain を直書きすると
# credential-osxkeychain が存在しない Linux/WSL で毎回
# 「git: 'credential-osxkeychain' is not a git command」が出るため。
# git は存在しない include パスを黙って無視するので、未生成でも壊れない。
[include]
  path = ~/.config/git/os.gitconfig
# [user] の name/email はマシン (と人) ごとに違うため tracked な .gitconfig に
# 直書きしない。直書きすると、この repo を clone した他人が手順どおり symlink
# を張った時点で、リポジトリ所有者の名義で黙ってコミットしてしまう。
# install.sh が ~/.config/git/user.gitconfig を生成する (既存があれば触らない)。
[include]
  path = ~/.config/git/user.gitconfig
[merge]
  tool = nvimdiff
[mergetool]
  prompt = false
  keepBackup = false
[mergetool "nvimdiff"]
  layout = "LOCAL,BASE,REMOTE / MERGED"
