# Codex CLI's own managed system skills (auto-installed at runtime, not ours)
.codex/skills/.system/

# Artifacts generated by this repo's own test suite
# (.pytest_cache/ and .ruff_cache/ self-ignore via their own .gitignore)
__pycache__/
.coverage
.coverage.*

# Safety net for environments where ~/.gitignore_global is not wired yet
# (fresh clone before install.sh, bare containers, worktrees).
# .serena/ writes its own .gitignore but it only covers cache/ and
# project.local.yml, and lazy-lock.json has no self-ignore at all.
tags
.DS_Store
.serena/
lazy-lock.json
