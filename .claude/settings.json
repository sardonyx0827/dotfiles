{
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Read(id_rsa)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Read(node_modules/**)",
      "Read(./node_modules/**)",
      "Read(.git/**)",
      "Read(./.git/**)",
      "Read(build/**)",
      "Read(./build/**)",
      "Read(dist/**)",
      "Read(./dist/**)",
      "Read(out/**)",
      "Read(./.next/**)"
    ]
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": 600000
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
