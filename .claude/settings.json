{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "MultiEdit",
      "WebSearch",
      "WebFetch",
      "LS",
      "Task",
      "TodoRead",
      "TodoWrite",
      "Bash(tmux:*)",
      "Bash(ls:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(touch:*)",
      "Bash(ln:*)",
      "Bash(realpath:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(export:*)",
      "Bash(date:*)",
      "Bash(sleep:*)",
      "Bash(uname:*)",
      "Bash(git:*)",
      "Bash(which:*)",
      "Bash(whereis:*)",
      "Bash(jq:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(next:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(pytest:*)",
      "Bash(mypy:*)",
      "Bash(black:*)",
      "Bash(ruff:*)",
      "Bash(rustfmt:*)",
      "Bash(clippy:*)",
      "Bash(vite:*)",
      "Bash(mkdir:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(flake8:*)",
      "Bash(pylint:*)",
      "Bash(cargo:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "mcp__serena__open_dashboard",
      "mcp__serena__activate_project",
      "mcp__serena__list_dir",
      "mcp__serena__list_memories",
      "mcp__serena__get_current_config",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__onboarding",
      "mcp__serena__read_memory",
      "mcp__serena__write_memory",
      "mcp__serena__delete_memory",
      "mcp__serena__rename_memory",
      "mcp__serena__edit_memory",
      "mcp__serena__find_symbol",
      "mcp__serena__find_referencing_symbol",
      "mcp__serena__find_file",
      "mcp__serena__search_for_pattern",
      "mcp__serena__replace_symbol_body",
      "mcp__serena__insert_after_symbol",
      "mcp__serena__insert_before_symbol",
      "mcp__serena__rename_symbol",
      "mcp__serena__install_instructions",
      "mcp__codex__codex",
      "mcp__codex__codex-reply",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Read(id_rsa)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(*.key)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Read(node_modules/**)",
      "Read(./node_modules/**)",
      "Read(.git/**)",
      "Read(./.git/**)",
      "Read(build/**)",
      "Read(./build/**)",
      "Read(dist/**)",
      "Read(./dist/**)",
      "Read(out/**)",
      "Read(./.next/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/lint.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/hooks/bash-review.py"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/git-push-review.sh",
            "if": "Bash(git push*)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stop-audit.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "code-review@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "excludedCommands": [
      "docker",
      "docker-compose",
      "git"
    ],
    "allowedNetworkHosts": [
      "github.com",
      "api.github.com",
      "registry.npmjs.org",
      "pypi.org",
      "files.pythonhosted.org",
      "crates.io",
      "static.crates.io"
    ]
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "autoMemoryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "editorMode": "normal",
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
