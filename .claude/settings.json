      "Bash(whereis:*)",
      "Bash(jq:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(next:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(pytest:*)",
      "Bash(mypy:*)",
      "Bash(black:*)",
      "Bash(ruff:*)",
