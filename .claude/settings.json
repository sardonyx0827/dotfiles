    "deny": [
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Read(id_rsa)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Read(node_modules/**)",
      "Read(./node_modules/**)",
      "Read(.git/**)",
      "Read(./.git/**)",
      "Read(build/**)",
      "Read(./build/**)",
      "Read(dist/**)",
      "Read(./dist/**)",
      "Read(out/**)",
      "Read(./.next/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/gemini-api-bash-review.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true
  },
  "sandbox": {
    "enabled": false,
    "excludedCommands": [
      "docker",
      "docker-compose",
      "git"
    ],
    "allowedNetworkHosts": [
      "github.com",
      "api.github.com",
      "registry.npmjs.org",
      "pypi.org",
      "files.pythonhosted.org",
      "crates.io",
      "static.crates.io"
    ]
  },
  "autoUpdatesChannel": "latest",
  "teammateMode": "tmux"
}
