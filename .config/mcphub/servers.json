{
  "mcpServers": {
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "command": "npx"
    },
    "serena": {
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--context",
        "ide-assistant",
        "--port",
        "32323"
      ],
      "command": "uvx",
      "env": [],
      "type": "stdio"
    }
  },
  "nativeMCPServers": {
    "neovim": {
      "custom_instructions": {
        "disabled": false,
        "text": ""
      },
      "disabled": false,
      "disabled_resources": [],
      "disabled_tools": []
    }
  }
}
