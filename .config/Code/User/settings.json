{
    // vim settings
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.leader": ",",
    "vim.useCtrlKeys": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "c",
                "c"
            ],
            "commands": [
                "claude-vscode.editor.open"
            ]
        },{
            "before": [
                "<leader>",
                "t",
                "c"
            ],
            "commands": [
                "claude-vscode.editor.open"
            ],

        }, {
            "before": [
                "<leader>",
                "d",
                "a"
            ],
            "commands": [
                "claude-vscode.acceptProposedDiff"
            ]
        }, {
            "before": [
                "<leader>",
                "d",
                "d"
            ],
            "commands": [
                "claude-vscode.rejectProposedDiff"
            ]
        },{
            "before": [
                "<leader>",
                "e"
            ],
            // open explorer
            "commands": [
                "workbench.view.explorer"
            ]
        },{
            "before": [
                "<leader>",
                "u"
            ],
            // timeline
            "commands": [
                "timeline.focus"
            ]
        },{
            "before": [
                "<leader>",
                "s",
                "f",
            ],
            // find in files
            "commands": [
                "workbench.action.quickOpen"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "r",
            ],
            // find in files
            "commands": [
                "workbench.action.findInFiles"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "c",
            ],
            // open source control
            "commands": [
                "workbench.view.scm"
            ]
        },{
            "before": [
                "<leader>",
                " ",
            ],
            // disable search highlight
            "commands": [
                ":noh"
            ]
        },{
            "before": [
                "u",
            ],
            "commands": [
                "undo"
            ]
        },{
            "before": [
                "<C-r>",
            ],
            "commands": [
                "redo"
            ]
        },{
            "before": [
                "<leader>",
                "r",
                "n",
            ],
            // search and replace
            "commands": [
                "editor.action.startFindReplaceAction"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "d",
            ],
            // git diff on current file
            "commands": [
                "git.openChange"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "n"
            ],
            // git next change
            "commands": [
                "workbench.action.editor.nextChange"
            ]
        },{
            "before": [
                "<leader>",
                "f",
                "f",
            ],
            // format document
            "commands": [
                "editor.action.formatDocument"
            ]
        },{
            "before": [
                "K",
            ],
            // definition preview
            "commands": [
                "editor.action.showDefinitionPreviewHover"
            ]
        },{
            "before": [
                "<C-t>",
            ],
            // jump to definition
            "commands": [
                "editor.action.revealDefinition"
            ]
        },{
            "before": [
                "<leader>",
                "b",
                "f",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "l",
                "s",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "s",
                "l",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "l",
                "l",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "p",
            ],
            // instead of Buffers
            "commands": [
                "workbench.action.files.openFolderInNewWindow"
            ]
        },{
            "before": [
                "g",
                "c",
                "c",
            ],
            // toggle comment
            "commands": [
                "editor.action.commentLine"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "w",
            ],
            // display all problems
            "commands": [
                "workbench.actions.view.problems"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "x",
            ],
            // display all problems
            "commands": [
                "workbench.actions.view.problems"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "n",
            ],
            // jump to next problem
            "commands": [
                "editor.action.marker.nextInFiles"
            ]
        },{
            "before": [
                "<leader>",
                "w",
                "w",
            ],
            "commands": [
                "workbench.action.compareEditor.focusOtherSide"
            ]
        },{
            "before": [
                "<leader>",
                "j",
                "j"
            ],
            // vim easy motion
            "after": [
                "leader",
                "leader",
                "leader",
                "b",
                "d",
                "w"
            ]
        },{
            "before": [
                "<C-h>"
            ],
            // vim easy motion
            "after": [
                "g",
                "T"
            ]
        },{
            "before": [
                "<C-l>"
            ],
            // vim easy motion
            "after": [
                "g",
                "t"
            ]
        }
    ],

    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "c",
                "c"
            ],
            "commands": [
                "claude-code.runClaude"
            ]
        },{
            "before": [
                "<leader>",
                "e"
            ],
            // open explorer
            "commands": [
                "workbench.view.explorer"
            ]
        },{
            "before": [
                "<leader>",
                "u"
            ],
            // timeline
            "commands": [
                "timeline.focus"
            ]
        },{
            "before": [
                ">",
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },{
            "before": [
                "<",
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        },{
            "before": [
                "g",
                "c",
            ],
            // toggle comment
            "commands": [
                "editor.action.commentLine"
            ]
        },
    ],

    "vim.insertModeKeyBindingsNonRecursive": [
        {
            // move cursor
            "before": [
                "<C-h>"
            ],
            "after": [
                "<C-o>",
                "h"
            ]
        },{
            "before": [
                "<C-l>"
            ],
            "after": [
                "<C-o>",
                "l"
            ]
        },{
            "before": [
                "<C-j>"
            ],
            "after": [
                "<C-o>",
                "g",
                "j"
            ]
        },{
            "before": [
                "<C-k>"
            ],
            "after": [
                "<C-o>",
                "g",
                "k"
            ]
        }
    ],
    // editor settings
    "workbench.startupEditor": "none",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "indentRainbow.indicatorStyle": "light",
    "vscode_vibrancy.opacity": 1.7,
    "vscode_vibrancy.refreshInterval": 10000,
    "glassit.alpha": 255,
    "editor.lineNumbers": "relative",
    "git.autofetch": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": true
    },
    "window.customMenuBarAltFocus": false,
    "window.titleBarStyle": "custom",
    "workbench.activityBar.location": "top",
    "editor.minimap.enabled": false,
    "explorer.confirmDragAndDrop": false,
    "window.enableMenuBarMnemonics": false,
    "[typescriptreact]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "github.copilot.advanced": {},
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.tabSize": 2,
    "github.copilot.chat.localeOverride": "ja",
    "vim.easymotion": true,
    "vim.easymotionKeys": "hklyuiopnmqwertzxcvbasdgjf",
    "window.customTitleBarVisibility": "auto",
    "security.promptForRemoteFileProtocolHandling": false,
    "cline.preferredLanguage": "Japanese - 日本語",
    "git.openRepositoryInParentFolders": "never",
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "windsurf": true,
        "cursor-global": true,
        "cursor-workspace": true
    },
    "remote.defaultExtensionsIfInstalledLocally": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-pull-request-github"
    ],
    "github.copilot.nextEditSuggestions.enabled": true,
    "chat.agent.enabled": true,
    "vim.showMarksInGutter": true,
    "git.confirmSync": false,
    // "workbench.colorTheme": "Tokyo Night",
}
