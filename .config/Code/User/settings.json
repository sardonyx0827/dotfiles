{
    // vim settings
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.leader": ",",
    "vim.useCtrlKeys": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<C-c>"
            ],
            // CopilotChat inline editor
            "commands": [
                "interactiveEditor.start"
            ]
        },{
            "before": [
                "<leader>",
                "c",
                "c"
            ],
            // CopilotChat
            "commands": [
                "workbench.panel.chat.view.copilot.focus"
            ]
        },{
            "before": [
                "<leader>",
                "e"
            ],
            // open explorer
            "commands": [
                "workbench.view.explorer"
            ]
        },{
            "before": [
                "<leader>",
                "u"
            ],
            // timeline
            "commands": [
                "timeline.focus"
            ]
        },{
            "before": [
                "<leader>",
                "s",
                "f",
            ],
            // find in files
            "commands": [
                "workbench.action.quickOpen"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "r",
            ],
            // find in files
            "commands": [
                "workbench.action.findInFiles"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "c",
            ],
            // open source control
            "commands": [
                "workbench.view.scm"
            ]
        },{
            "before": [
                "<leader>",
                " ",
            ],
            // disable search highlight
            "commands": [
                ":noh"
            ]
        },{
            "before": [
                "u",
            ],
            "commands": [
                "undo"
            ]
        },{
            "before": [
                "<C-r>",
            ],
            "commands": [
                "redo"
            ]
        },{
            "before": [
                "<leader>",
                "r",
                "n",
            ],
            // search and replace
            "commands": [
                "editor.action.startFindReplaceAction"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "d",
            ],
            // git diff on current file
            "commands": [
                "git.openChange"
            ]
        },{
            "before": [
                "<leader>",
                "g",
                "n"
            ],
            // git next change
            "commands": [
                "workbench.action.editor.nextChange"
            ]
        },{
            "before": [
                "<leader>",
                "f",
                "f",
            ],
            // format document
            "commands": [
                "editor.action.formatDocument"
            ]
        },{
            "before": [
                "K",
            ],
            // definition preview
            "commands": [
                "editor.action.showDefinitionPreviewHover"
            ]
        },{
            "before": [
                "<C-t>",
            ],
            // jump to definition
            "commands": [
                "editor.action.revealDefinition"
            ]
        },{
            "before": [
                "<leader>",
                "b",
                "f",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "l",
                "s",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "s",
                "l",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "l",
                "l",
            ],
            // instead of Buffers
            "commands": [
                "workbench.files.action.focusOpenEditorsView"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "p",
            ],
            // instead of Buffers
            "commands": [
                "workbench.action.files.openFolderInNewWindow"
            ]
        },{
            "before": [
                "g",
                "c",
                "c",
            ],
            // toggle comment
            "commands": [
                "editor.action.commentLine"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "w",
            ],
            // display all problems
            "commands": [
                "workbench.actions.view.problems"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "x",
            ],
            // display all problems
            "commands": [
                "workbench.actions.view.problems"
            ]
        },{
            "before": [
                "<leader>",
                "x",
                "n",
            ],
            // jump to next problem
            "commands": [
                "editor.action.marker.nextInFiles"
            ]
        },{
            "before": [
                "<leader>",
                "q",
                "f",
            ],
            // quick fix(using Copilot)
            "commands": [
                "editor.action.marker.nextInFiles",
                // "interactiveEditor.start",
                "editor.action.quickFix",
            ]
        },{
            "before": [
                "<leader>",
                "w",
                "w",
            ],
            "commands": [
                "workbench.action.compareEditor.focusOtherSide"
            ]
        },{
            "before": [
                "<leader>",
                "j",
                "j"
            ],
            // vim easy motion
            "after": [
                "leader",
                "leader",
                "leader",
                "b",
                "d",
                "w"
            ]
        }
    ],

    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<C-c>"
            ],
            // CopilotChat inline editor
            "commands": [
                "interactiveEditor.start"
            ]
        },{
            "before": [
                "<leader>",
                "c",
                "c"
            ],
            // CopilotChat inline editor
            "commands": [
                "workbench.panel.chat.view.copilot.focus"
            ]
        },{
            "before": [
                "<leader>",
                "e"
            ],
            // open explorer
            "commands": [
                "workbench.view.explorer"
            ]
        },{
            "before": [
                "<leader>",
                "u"
            ],
            // timeline
            "commands": [
                "timeline.focus"
            ]
        },{
            "before": [
                ">",
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },{
            "before": [
                "<",
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        },{
            "before": [
                "g",
                "c",
            ],
            // toggle comment
            "commands": [
                "editor.action.commentLine"
            ]
        }
    ],

    "vim.insertModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<C-c>"
            ],
            // CopilotChat inline editor
            "commands": [
                "interactiveEditor.start"
            ]
        },{
        //     "before": [
        //         "<C-j>"
        //     ],
        //     // Copilot suggestion(next)
        //     "commands": [
        //         "editor.action.inlineSuggest.showNext"
        //     ]
        // },{
        //     "before": [
        //         "<C-k>"
        //     ],
        //     // Copilot suggestion(previous)
        //     "commands": [
        //         "editor.action.inlineSuggest.showPrevious"
        //     ]
        // },{
            // move cursor
            "before": [
                "<C-h>"
            ],
            "after": [
                "<C-o>",
                "h"
            ]
        },{
            "before": [
                "<C-l>"
            ],
            "after": [
                "<C-o>",
                "l"
            ]
        },{
            "before": [
                "<C-j>"
            ],
            "after": [
                "<C-o>",
                "g",
                "j"
            ]
        },{
            "before": [
                "<C-k>"
            ],
            "after": [
                "<C-o>",
                "g",
                "k"
            ]
        }
    ],
    // editor settings
    "workbench.startupEditor": "none",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "indentRainbow.indicatorStyle": "light",
    "vscode_vibrancy.opacity": 1.7,
    "vscode_vibrancy.refreshInterval": 10000,
    "glassit.alpha": 255,
    "editor.lineNumbers": "relative",
    "git.autofetch": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": true
    },
    //"workbench.editor.showTabs": "single",
    "window.customMenuBarAltFocus": false,
    "window.titleBarStyle": "custom",
    "workbench.activityBar.location": "top",
    "editor.minimap.enabled": false,
    "explorer.confirmDragAndDrop": false,
    "CodeGPT.apiKey": "Google AI Studio",
    "CodeGPT.query.language": "Japanese",
    "CodeGPT.Autocomplete.enabled": false,
    "window.enableMenuBarMnemonics": false,
    "continue.enableTabAutocomplete": false,
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "continue.showInlineTip": false,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "github.copilot.advanced": {},
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.tabSize": 2,
    "github.copilot.chat.localeOverride": "ja",
    "vim.easymotion": true,
    "vim.easymotionKeys": "hklyuiopnmqwertzxcvbasdgjf",
    //"continue.remoteConfigServerUrl": "http://localhost:11434/api/codegemma",
}
