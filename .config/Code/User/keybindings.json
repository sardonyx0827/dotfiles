// Place your key bindings in this file to override the defaults
[
    // instead of enter
    {
        "key": "ctrl+m",
        "command": "type",
        "args": {
            "text": "\n"
        },
        "when": "editorTextFocus"
    },
    // instead of ESC
    {
        "key": "ctrl+[",
        "command": "extension.vim_escape",
    },
    // instead of undotree
    {
        "key": "ctrl+shift+t",
        "command": "timeline.focus"
    },
    // find and replace in current file
    {
        "key": "ctrl+shift+r",
        "command": "editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "ctrl+h",
        "command": "-editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    // show help page
    {
        "key": "ctrl+shift+h",
        "command": "workbench.action.keybindingsReference"
    },
    {
        "key": "ctrl+k ctrl+r",
        "command": "-workbench.action.keybindingsReference"
    },
    // // copilot generate
    {
        "key": "ctrl+enter",
        "command": "-github.copilot.generate",
        "when": "editorTextFocus && github.copilot.activated && !inInteractiveInput && !interactiveEditorFocused"
    },
    // find and replace in workbench
    {
        "key": "ctrl+shift+s",
        "command": "workbench.action.findInFiles"
    },
    {
        "key": "ctrl+shift+f",
        "command": "-workbench.action.findInFiles"
    },
    // format document
    {
        "key": "ctrl+shift+f",
        "command": "editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
    },
    {
        "key": "ctrl+shift+i",
        "command": "-editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
    },
    // format document none
    {
        "key": "ctrl+shift+f",
        "command": "editor.action.formatDocument.none",
        "when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
    },
    {
        "key": "ctrl+shift+i",
        "command": "-editor.action.formatDocument.none",
        "when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
    },
    {
        "key": "alt+enter",
        "command": "github.copilot.acceptCursorPanelSolution",
        "when": "github.copilot.activated && github.copilot.panelVisible"
    },
    {
        "key": "ctrl+/",
        "command": "-github.copilot.acceptCursorPanelSolution",
        "when": "github.copilot.activated && github.copilot.panelVisible"
    },
    {
        "key": "ctrl+m",
        "command": "-editor.action.toggleTabFocusMode"
    },
    // toggle copilot chat side window
    {
        "key": "ctrl+shift+i",
        "command": "workbench.panel.chat",
    },
    {
        "key": "ctrl+shift+o",
        "command": "claude-code.runClaude",
    },
    {
        "key": "ctrl+a ctrl+n",
        "command": "claude-code.runClaude",
    },
    // delete opened buffer
    {
        "key": "alt+x",
        "command": "workbench.action.closeActiveEditor"
    },
    {
        "key": "cmd+x",
        "command": "workbench.action.closeActiveEditor"
    },
    // explorer actions
    // create new file
    {
        "key": "a",
        "command": "explorer.newFile",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    // create new dir
    {
        "key": "shift+a",
        "command": "explorer.newFolder",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    // rename
    {
        "key": "r",
        "command": "renameFile",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    // open with vertical split window
    {
        "key": "ctrl+v",
        "command": "explorer.openToSide",
        "when": "explorerViewletFocus && foldersViewVisible && !inputFocus"
    },
    // delete file
    {
        "key": "d",
        "command": "moveFileToTrash",
        "when": "explorerResourceMoveableToTrash && filesExplorerFocus && foldersViewVisible && !explorerResourceReadonly && !inputFocus"
    },
    // stage all changes (git)
    {
        "key": "shift+s",
        "command": "git.stageAll",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    // stage changes (git)
    {
        "key": "ctrl+s",
        "command": "git.stage",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    // unstage changes (git)
    {
        "key": "ctrl+u",
        "command": "git.unstageAll",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    // commit (git)
    {
        "key": "ctrl+c",
        "command": "git.commitStaged",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    // push (git)
    {
        "key": "shift+p",
        "command": "git.push",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    // push (fetch)
    {
        "key": "ctrl+f",
        "command": "git.fetch",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    // pull (git)
    {
        "key": "ctrl+p",
        "command": "git.pull",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    // focus text editor
    {
        "key": "alt+f",
        "command": "workbench.action.focusFirstEditorGroup"
    },
    {
        // focus text editor
        "key": "cmd+f",
        "command": "workbench.action.focusFirstEditorGroup"
    },
    {
        // save file
        "key": "ctrl+s",
        "command": "workbench.action.files.save",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        // copilot chat inline
        "key": "ctrl+c",
        "command": "inlineChat.start",
        "when": "editorFocus && inlineChatHasProvider && !editorReadonly"
    },
    {
        // copilot chat inline
        "key": "ctrl+i",
        "command": "-inlineChat.start",
        "when": "editorFocus && inlineChatHasProvider && !editorReadonly"
    },
    {
        // open file and close explorer
        "key": "l",
        "command": "runCommands",
        "args": {
            "commands": [
                "explorer.openAndPassFocus",
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus && !explorerResourceIsFolder"
    },
    {
        // expand folder in explorer
        "key": "l",
        "command": "list.expand",
        "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus && explorerResourceIsFolder"
    },
    {
        // open search result and close sidebar
        "key": "l",
        "command": "runCommands",
        "args": {
            "commands": [
                "search.action.openResult",
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        "when": "searchViewletVisible && !inputFocus && hasSearchResult && listFocus"
    },
    {
        // insert line break in terminal
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\\\r\n"
        },
        "when": "terminalFocus"
    },
    {
        // move to next in quick open
        "key": "ctrl+n",
        "command": "workbench.action.quickOpenNavigateNext",
        "when": "inQuickOpen"
    },
    {
        // move to previous in quick open
        "key": "ctrl+p",
        "command": "workbench.action.quickOpenNavigatePrevious",
        "when": "inQuickOpen"
    },
    {
        // move to search results
        "key": "ctrl+j",
        "command": "search.action.focusSearchList",
        "when": "searchViewletVisible"
    }
]
