// Place your key bindings in this file to override the defaults
[
  {
    // instead of enter
    "key": "ctrl+m",
    "command": "type",
    "args": {
      "text": "\n"
    },
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+m",
    "command": "workbench.action.acceptSelectedQuickOpenItem",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+m",
    "command": "list.select",
    "when": "listFocus && !inputFocus"
  },
  {
    // instead of ESC
    "key": "ctrl+[",
    "command": "extension.vim_escape",
    "when": "editorTextFocus"
  },
  {
    // hide hover
    "key": "ctrl+[",
    "command": "editor.action.hideHover",
    "when": "editorHoverVisible"
  },
  {
    "key": "ctrl+[",
    "command": "workbench.action.blur",
    "when": "!editorFocus"
  },
  {
    // instead of undotree
    "key": "ctrl+shift+t",
    "command": "timeline.focus",
    "when": "editorTextFocus"
  },
  {
    // find and replace in current file
    "key": "ctrl+shift+r",
    "command": "editor.action.startFindReplaceAction",
    "when": "editorFocus || editorIsOpen"
  },
  {
    "key": "ctrl+h",
    "command": "-editor.action.startFindReplaceAction",
    "when": "editorFocus || editorIsOpen"
  },
  {
    // show help page
    "key": "ctrl+shift+h",
    "command": "workbench.action.keybindingsReference"
  },
  {
    "key": "ctrl+k ctrl+r",
    "command": "-workbench.action.keybindingsReference"
  },
  {
    // // copilot generate
    "key": "ctrl+enter",
    "command": "-github.copilot.generate",
    "when": "editorTextFocus && github.copilot.activated && !inInteractiveInput && !interactiveEditorFocused"
  },
  {
    // find and replace in workbench
    "key": "ctrl+shift+s",
    "command": "workbench.action.findInFiles"
  },
  {
    "key": "ctrl+shift+f",
    "command": "-workbench.action.findInFiles"
  },
  {
    // format document
    "key": "ctrl+shift+f",
    "command": "editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
  },
  {
    "key": "ctrl+shift+i",
    "command": "-editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
  },
  {
    // format document none
    "key": "ctrl+shift+f",
    "command": "editor.action.formatDocument.none",
    "when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
  },
  {
    "key": "ctrl+shift+i",
    "command": "-editor.action.formatDocument.none",
    "when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
  },
  {
    "key": "alt+enter",
    "command": "github.copilot.acceptCursorPanelSolution",
    "when": "github.copilot.activated && github.copilot.panelVisible"
  },
  {
    "key": "ctrl+/",
    "command": "-github.copilot.acceptCursorPanelSolution",
    "when": "github.copilot.activated && github.copilot.panelVisible"
  },
  {
    "key": "ctrl+m",
    "command": "-editor.action.toggleTabFocusMode"
  },
  {
    // toggle copilot chat side window
    "key": "ctrl+shift+i",
    "command": "workbench.panel.chat"
  },
  {
    "key": "ctrl+shift+o",
    "command": "claude-code.runClaude"
  },
  {
    "key": "ctrl+a ctrl+n",
    "command": "claude-code.runClaude"
  },
  {
    // delete opened buffer
    "key": "alt+x",
    "command": "workbench.action.closeActiveEditor"
  },
  {
    "key": "cmd+x",
    "command": "workbench.action.closeActiveEditor"
  }, // explorer actions
  {
    // create new file
    "key": "a",
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    // create new dir
    "key": "shift+a",
    "command": "explorer.newFolder",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    // rename
    "key": "r",
    "command": "renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    // open with vertical split window
    "key": "ctrl+v",
    "command": "runCommands",
    "args": {
      "commands": [
        "explorer.openToSide",
        "workbench.action.toggleSidebarVisibility",
        "extension.vim_escape"
      ]
    },
    "when": "explorerViewletFocus && foldersViewVisible && !inputFocus"
  },
  {
    // delete file
    "key": "d",
    "command": "moveFileToTrash",
    "when": "explorerResourceMoveableToTrash && filesExplorerFocus && foldersViewVisible && !explorerResourceReadonly && !inputFocus"
  },
  {
    // stage all changes (git)
    "key": "ctrl+g shift+s",
    "command": "git.stageAll",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    // stage changes (git)
    "key": "ctrl+g s",
    "command": "git.stageAll",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    // unstage changes (git)
    "key": "ctrl+g u",
    "command": "git.unstageAll",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    // generate commit message (git)
    "key": "ctrl+g m",
    "command": "github.copilot.git.generateCommitMessage"
  },
  {
    // commit (git)
    "key": "ctrl+g c",
    "command": "git.commitStaged",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    // push (git)
    "key": "ctrl+g shift+p",
    "command": "git.push",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    // fetch (git)
    "key": "ctrl+g f",
    "command": "git.fetch",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    // pull (git)
    "key": "ctrl+g p",
    "command": "git.pull",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    // focus editor from scm input box
    "key": "ctrl+w l",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "sideBarFocus"
  },
  {
    // focus text editor
    "key": "alt+f",
    "command": "workbench.action.focusFirstEditorGroup"
  },
  {
    // save file
    "key": "ctrl+s",
    "command": "workbench.action.files.save",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    // copilot chat inline
    "key": "ctrl+c",
    "command": "inlineChat.start",
    "when": "editorFocus && inlineChatPossible && !editorReadonly"
  },
  {
    // copilot chat inline
    "key": "ctrl+i",
    "command": "-inlineChat.start",
    "when": "editorFocus && inlineChatHasProvider && !editorReadonly"
  },
  {
    // open file and close explorer
    "key": "l",
    "command": "runCommands",
    "args": {
      "commands": [
        "explorer.openAndPassFocus",
        "workbench.action.toggleSidebarVisibility"
      ]
    },
    "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus && !explorerResourceIsFolder"
  },
  {
    // open timeline and close sidebar
    "key": "l",
    "command": "runCommands",
    "args": {
      "commands": ["list.select", "workbench.action.toggleSidebarVisibility"]
    },
    "when": "focusedView == 'timeline' && listFocus && !inputFocus"
  },
  {
    // expand folder in explorer
    "key": "l",
    "command": "list.expand",
    "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus && explorerResourceIsFolder"
  },
  {
    // open search result and close sidebar
    "key": "l",
    "command": "runCommands",
    "args": {
      "commands": [
        "search.action.openResult",
        "workbench.action.toggleSidebarVisibility",
        "extension.vim_escape"
      ]
    },
    "when": "searchViewletVisible && !inputFocus && hasSearchResult && listFocus"
  },
  {
    // insert line break in terminal
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": {
      "text": "\\\r\n"
    },
    "when": "terminalFocus"
  },
  {
    // move to next in quick open
    "key": "ctrl+n",
    "command": "workbench.action.quickOpenNavigateNext",
    "when": "inQuickOpen"
  },
  {
    // move to previous in quick open
    "key": "ctrl+p",
    "command": "workbench.action.quickOpenNavigatePrevious",
    "when": "inQuickOpen"
  },
  {
    // move to search results
    "key": "ctrl+j",
    "command": "search.action.focusSearchList",
    "when": "searchViewletVisible"
  },
  {
    // move to search box from search results
    "key": "ctrl+k",
    "command": "workbench.action.findInFiles",
    "when": "searchViewletVisible"
  },
  {
    // move to right side panels from editor
    "key": "ctrl+w l",
    "command": "workbench.action.focusAuxiliaryBar",
    "when": "!inChatInput && !chatViewFocus && editorTextFocus && auxiliaryBarVisible"
  },
  {
    // move to right editor group
    "key": "ctrl+w l",
    "command": "workbench.action.focusNextGroup",
    "when": "editorTextFocus && !auxiliaryBarVisible"
  },
  {
    // move to left editor group from right side panels
    // move to editor from right side panels
    "key": "ctrl+w h",
    "command": "workbench.action.focusPreviousGroup"
  },
  {
    // move to bottom editor group
    "key": "ctrl+w j",
    "command": "workbench.action.focusBelowGroup",
    "when": "editorTextFocus"
  },
  {
    // move to top editor group
    "key": "ctrl+w k",
    "command": "workbench.action.focusAboveGroup",
    "when": "editorTextFocus"
  },
  {
    // move to terminal when terminal is opened
    "key": "ctrl+w j",
    "command": "workbench.action.terminal.focus",
    "when": "editorTextFocus && terminalIsOpen"
  },
  {
    // move to editor from terminal when terminal is opened
    "key": "ctrl+w k",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus"
  },
  {
    // open vertical split editor
    "key": "ctrl+w ctrl+v",
    "command": "workbench.action.splitEditorRight",
    "when": "editorTextFocus"
  },
  {
    // open horizontal split editor
    "key": "ctrl+w ctrl+s",
    "command": "workbench.action.splitEditorDown",
    "when": "editorTextFocus"
  },
  {
    // close primary sidebar
    "key": "ctrl+w q",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "sideBarVisible && sideBarFocus"
  },
  {
    // close secondary sidebar
    "key": "ctrl+w q",
    "command": "workbench.action.closeAuxiliaryBar",
    "when": "auxiliaryBarVisible && auxiliaryBarFocus"
  },
  {
    // close editor(claude code chat window, otherwise)
    "key": "ctrl+w q",
    "command": "workbench.action.closeAuxiliaryBar",
    "when": "activeEditor && !editorLangId && !sideBarFocus && !auxiliaryBarFocus"
  },
  {
    // close editor
    "key": "ctrl+w q",
    "command": "workbench.action.closeActiveEditor",
    "when": "activeEditor && editorLangId && !sideBarFocus && !auxiliaryBarFocus"
  },
  {
    // close explorer
    "key": "q",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    // close terminal
    "key": "ctrl+w q",
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus"
  },
  {
    // switch editor group Left to Right
    "key": "ctrl+w shift+l",
    "command": "workbench.action.moveActiveEditorGroupRight",
    "when": "editorTextFocus"
  },
  {
    // switch editor group Right to Left
    "key": "ctrl+w shift+h",
    "command": "workbench.action.moveActiveEditorGroupLeft",
    "when": "editorTextFocus"
  },
  {
    // switch editor group top to Bottom
    "key": "ctrl+w shift+j",
    "command": "workbench.action.moveActiveEditorGroupDown",
    "when": "editorTextFocus"
  },
  {
    // switch editor group Bottom to top
    "key": "ctrl+w shift+k",
    "command": "workbench.action.moveActiveEditorGroupUp",
    "when": "editorTextFocus"
  },
  {
    // window size increase height
    "key": "ctrl+right",
    "command": "workbench.action.increaseViewSize"
  },
  {
    // window size decrease height
    "key": "ctrl+left",
    "command": "workbench.action.decreaseViewSize"
  },
  {
    "key": "ctrl+up",
    "command": "workbench.action.increaseViewHeight"
  },
  {
    "key": "ctrl+down",
    "command": "workbench.action.decreaseViewHeight"
  },
  {
    // close other editor groups
    "key": "ctrl+w o",
    "command": "workbench.action.closeEditorsInOtherGroups",
    "when": "editorTextFocus"
  },
  {
    // reload window and extensions
    "key": "ctrl+r x",
    "command": "workbench.action.reloadWindow",
    "when": "sideBarFocus"
  },
  {
    // jump to next snippet placeholder
    "key": "ctrl+f",
    "command": "jumpToNextSnippetPlaceholder",
    "when": "editorTextFocus && inSnippetMode"
  },
  {
    // jump to previous snippet placeholder
    "key": "ctrl+b",
    "command": "jumpToPrevSnippetPlaceholder",
    "when": "editorTextFocus && inSnippetMode"
  },
  {
    // explorer navigation down and preview file
    "key": "j",
    "command": "runCommands",
    "args": {
      "commands": ["list.focusDown", "filesExplorer.openFilePreserveFocus"]
    },
    "when": "filesExplorerFocus && foldersViewVisible && !inputFocus"
  },
  {
    // explorer navigation up and preview file
    "key": "k",
    "command": "runCommands",
    "args": {
      "commands": ["list.focusUp", "filesExplorer.openFilePreserveFocus"]
    },
    "when": "filesExplorerFocus && foldersViewVisible && !inputFocus"
  },
  {
    // explorer navigation down and preview file
    "key": "Down",
    "command": "runCommands",
    "args": {
      "commands": ["list.focusDown", "filesExplorer.openFilePreserveFocus"]
    },
    "when": "filesExplorerFocus && foldersViewVisible && !inputFocus"
  },
  {
    // explorer navigation up and preview file
    "key": "Up",
    "command": "runCommands",
    "args": {
      "commands": ["list.focusUp", "filesExplorer.openFilePreserveFocus"]
    },
    "when": "filesExplorerFocus && foldersViewVisible && !inputFocus"
  },
  {
    // ask-ai extension settings
    "key": "ctrl+c",
    "command": "askAi.replaceWithClaude",
    "when": "editorTextFocus && vim.mode =~ /^Visual/"
  },
  {
    // ask-ai extension settings
    "key": "ctrl+x",
    "command": "askAi.replaceWithCodex",
    "when": "editorTextFocus && vim.mode =~ /^Visual/"
  },
  {
    // ask-ai extension settings
    "key": "ctrl+g",
    "command": "askAi.replaceWithGemini",
    "when": "editorTextFocus && vim.mode =~ /^Visual/"
  },
  {
    // ask-ai extension settings
    "key": "ctrl+o",
    "command": "askAi.replaceWithOllama",
    "when": "editorTextFocus && vim.mode =~ /^Visual/"
  },
  {
    // ask-ai extension settings
    "key": "ctrl+l",
    "command": "askAi.replaceWithAll",
    "when": "editorTextFocus && vim.mode =~ /^Visual/"
  }
]
