// Place your key bindings in this file to override the defaults
[
    {
        // instead of enter
        "key": "ctrl+m",
        "command": "type",
        "args": {
            "text": "\n"
        },
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+m",
        "command": "workbench.action.acceptSelectedQuickOpenItem",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+m",
        "command": "list.select",
        "when": "listFocus && !inputFocus"
    },
    {
        // instead of ESC
        "key": "ctrl+[",
        "command": "extension.vim_escape",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+[",
        "command": "workbench.action.blur",
        "when": "!editorFocus"
    },
    {
        // instead of undotree
        "key": "ctrl+shift+t",
        "command": "timeline.focus",
        "when": "editorTextFocus"
    },
    {
        // find and replace in current file
        "key": "ctrl+shift+r",
        "command": "editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "ctrl+h",
        "command": "-editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    {
        // show help page
        "key": "ctrl+shift+h",
        "command": "workbench.action.keybindingsReference"
    },
    {
        "key": "ctrl+k ctrl+r",
        "command": "-workbench.action.keybindingsReference"
    },
    {
        // // copilot generate
        "key": "ctrl+enter",
        "command": "-github.copilot.generate",
        "when": "editorTextFocus && github.copilot.activated && !inInteractiveInput && !interactiveEditorFocused"
    },
    {
        // find and replace in workbench
        "key": "ctrl+shift+s",
        "command": "workbench.action.findInFiles"
    },
    {
        "key": "ctrl+shift+f",
        "command": "-workbench.action.findInFiles"
    },
    {
        // format document
        "key": "ctrl+shift+f",
        "command": "editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
    },
    {
        "key": "ctrl+shift+i",
        "command": "-editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
    },
    {
        // format document none
        "key": "ctrl+shift+f",
        "command": "editor.action.formatDocument.none",
        "when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
    },
    {
        "key": "ctrl+shift+i",
        "command": "-editor.action.formatDocument.none",
        "when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
    },
    {
        "key": "alt+enter",
        "command": "github.copilot.acceptCursorPanelSolution",
        "when": "github.copilot.activated && github.copilot.panelVisible"
    },
    {
        "key": "ctrl+/",
        "command": "-github.copilot.acceptCursorPanelSolution",
        "when": "github.copilot.activated && github.copilot.panelVisible"
    },
    {
        "key": "ctrl+m",
        "command": "-editor.action.toggleTabFocusMode"
    },
    {
        // toggle copilot chat side window
        "key": "ctrl+shift+i",
        "command": "workbench.panel.chat",
    },
    {
        "key": "ctrl+shift+o",
        "command": "claude-code.runClaude",
    },
    {
        "key": "ctrl+a ctrl+n",
        "command": "claude-code.runClaude",
    },
    {
        // delete opened buffer
        "key": "alt+x",
        "command": "workbench.action.closeActiveEditor"
    },
    {
        "key": "cmd+x",
        "command": "workbench.action.closeActiveEditor"
    },
    // explorer actions
    {
        // create new file
        "key": "a",
        "command": "explorer.newFile",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // create new dir
        "key": "shift+a",
        "command": "explorer.newFolder",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // rename
        "key": "r",
        "command": "renameFile",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // open with vertical split window
        "key": "ctrl+v",
        "command": "runCommands",
        "args": {
            "commands": [
                "explorer.openToSide",
                "workbench.action.toggleSidebarVisibility",
                "extension.vim_escape"
            ]
        },
        "when": "explorerViewletFocus && foldersViewVisible && !inputFocus"
    },
    {
        // delete file
        "key": "d",
        "command": "moveFileToTrash",
        "when": "explorerResourceMoveableToTrash && filesExplorerFocus && foldersViewVisible && !explorerResourceReadonly && !inputFocus"
    },
    {
        // stage all changes (git)
        "key": "ctrl+g shift+s",
        "command": "git.stageAll",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    {
        // stage changes (git)
        "key": "ctrl+g s",
        "command": "git.stage",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    {
        // unstage changes (git)
        "key": "ctrl+g u",
        "command": "git.unstageAll",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    {
        // generate commit message (git)
        "key": "ctrl+g m",
        "command": "github.copilot.git.generateCommitMessage"
    },
    {
        // commit (git)
        "key": "ctrl+g c",
        "command": "git.commitStaged",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    {
        // push (git)
        "key": "ctrl+g shift+p",
        "command": "git.push",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    {
        // fetch (git)
        "key": "ctrl+g f",
        "command": "git.fetch",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    {
        // pull (git)
        "key": "ctrl+g p",
        "command": "git.pull",
        "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    },
    {
        // focus editor from scm input box
        "key": "ctrl+w l",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "sideBarFocus"
    },
    {
        // focus scm input box from editor
        "key": "ctrl+w h",
        "command": "workbench.view.scm",
        "when": "editorTextFocus"
    },
    {
        // focus text editor
        "key": "alt+f",
        "command": "workbench.action.focusFirstEditorGroup"
    },
    {
        // save file
        "key": "ctrl+s",
        "command": "workbench.action.files.save",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        // copilot chat inline
        "key": "ctrl+c",
        "command": "inlineChat.start",
        "when": "editorFocus && inlineChatHasProvider && !editorReadonly"
    },
    {
        // copilot chat inline
        "key": "ctrl+i",
        "command": "-inlineChat.start",
        "when": "editorFocus && inlineChatHasProvider && !editorReadonly"
    },
    {
        // open file and close explorer
        "key": "l",
        "command": "runCommands",
        "args": {
            "commands": [
                "explorer.openAndPassFocus",
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus && !explorerResourceIsFolder"
    },
    {
        // expand folder in explorer
        "key": "l",
        "command": "list.expand",
        "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus && explorerResourceIsFolder"
    },
    {
        // open search result and close sidebar
        "key": "l",
        "command": "runCommands",
        "args": {
            "commands": [
                "search.action.openResult",
                "workbench.action.toggleSidebarVisibility",
                "extension.vim_escape"
            ]
        },
        "when": "searchViewletVisible && !inputFocus && hasSearchResult && listFocus"
    },
    {
        // insert line break in terminal
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\\\r\n"
        },
        "when": "terminalFocus"
    },
    {
        // move to next in quick open
        "key": "ctrl+n",
        "command": "workbench.action.quickOpenNavigateNext",
        "when": "inQuickOpen"
    },
    {
        // move to previous in quick open
        "key": "ctrl+p",
        "command": "workbench.action.quickOpenNavigatePrevious",
        "when": "inQuickOpen"
    },
    {
        // move to search results
        "key": "ctrl+j",
        "command": "search.action.focusSearchList",
        "when": "searchViewletVisible"
    },{
        // move to search box from search results
        "key": "ctrl+k",
        "command": "workbench.action.findInFiles",
        "when": "searchViewletVisible"

    },{
        // move to editor from right side panels
        "key": "ctrl+w h",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "inChatInput || chatViewFocus"
    },{
        // move to right side panels from editor
        "key": "ctrl+w l",
        "command": "workbench.panel.chat.view.copilot.focus",
        "when": "!inChatInput && !chatViewFocus && editorTextFocus && auxiliaryBarVisible"
    },
    {
        // move to right editor group
        "key": "ctrl+w l",
        "command": "workbench.action.focusNextGroup",
        "when": "editorTextFocus && !auxiliaryBarVisible"
    },
    {
        // move to left editor group from right side panels
        "key": "ctrl+w h",
        "command": "workbench.action.focusPreviousGroup",
        "when": "!editorTextFocus"
    },
    {
        // move to left editor group
        "key": "ctrl+w h",
        "command": "workbench.action.focusPreviousGroup",
        "when": "editorTextFocus"
    },
    {
        // close primary sidebar
        "key": "ctrl+w q",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "sideBarVisible && sideBarFocus"
    },
    {
        // close secondary sidebar
        "key": "ctrl+w q",
        "command": "workbench.action.closeAuxiliaryBar",
        "when": "auxiliaryBarVisible && auxiliaryBarFocus"
    },
    {
        // close editor(claude code chat window, otherwise)
        "key": "ctrl+w q",
        "command": "workbench.action.closeActiveEditor",
        "when": "activeEditor && !editorLangId && !sideBarFocus && !auxiliaryBarFocus"
    },
    {
        // close editor
        "key": "ctrl+w q",
        "command": "workbench.action.closeActiveEditor",
        "when": "activeEditor && editorLangId && !sideBarFocus && !auxiliaryBarFocus"
    },
    {
        // close explorer
        "key": "q",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "filesExplorerFocus"
    },
    {
        // close terminal
        "key": "ctrl+w q",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus"
    },
    {
        // move to right tab
        "key": "ctrl+l",
        "command": "workbench.action.nextEditor"
    },
    {
        // move to left tab
        "key": "ctrl+h",
        "command": "workbench.action.previousEditor"
    },
    {
        // switch editor group 1 to 2
        "key": "ctrl+w shift+l",
        "command": "workbench.action.moveActiveEditorGroupRight",
        "when": "editorTextFocus"
    },
    {
        // switch editor group 2 to 1
        "key": "ctrl+w shift+h",
        "command": "workbench.action.moveActiveEditorGroupLeft",
        "when": "editorTextFocus"
    }
]
