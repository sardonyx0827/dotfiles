{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '__HOME__/.codex/hooks/bash-review.py'"
          },
          {
            "type": "command",
            "command": "bash '__HOME__/.codex/hooks/git-push-review.sh'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "'__HOME__/.codex/hooks/lint.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'__HOME__/.codex/hooks/auto-format.sh'"
          },
          {
            "type": "command",
            "command": "bash '__HOME__/.codex/hooks/stop-audit.sh'"
          }
        ]
      }
    ]
  }
}
